<launch>
  <!-- ========== Demo ==========
       Main launch file for MoveIt + RViz simulation of the star_ arm.

       Usage:
         roslaunch star__moveit_config demo.launch
  -->
  <arg name="debug" default="false" />
  <arg name="pipeline" default="ompl" />

  <!-- Fake trajectory execution for simulation -->
  <arg name="fake_execution" default="true" />

  <!-- Move Group (planning server) -->
  <include
    file="$(find star__moveit_config)/launch/move_group.launch">
    <arg name="debug" value="$(arg debug)" />
    <arg name="pipeline" value="$(arg pipeline)" />
    <arg name="allow_trajectory_execution" value="$(arg fake_execution)" />
  </include>

  <!-- RViz with MoveIt plugin + joint state publisher -->
  <include
    file="$(find star__moveit_config)/launch/moveit_rviz.launch">
    <arg name="debug" value="$(arg debug)" />
  </include>
</launch>
